# Copy this file to frontend/.env and fill in your own values.

# Mapbox access token — required for the map.
# Get one at https://account.mapbox.com/access-tokens/
VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# Supabase — required for real signup/login (and, later, saved routes).
# From https://app.supabase.com -> your project -> Project Settings -> API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Optional: backend base URL. Defaults to http://localhost:3000 if unset.
# VITE_API_URL=http://localhost:3000
